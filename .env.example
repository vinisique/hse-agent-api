# Groq
GROQ_API_KEY=gsk_coloque-sua-chave-aqui

# Chave compartilhada com o Next.js (Bearer token)
API_SECRET_KEY=gere-uma-string-aleatoria-e-segura-aqui

# PostgreSQL + pgvector (módulo RAG — opcional)
# Se não configurado, o RAG é desabilitado silenciosamente
PG_HOST=localhost
PG_PORT=5432
PG_DB=hse_normas
PG_USER=postgres
PG_PASSWORD=sua-senha-aqui
