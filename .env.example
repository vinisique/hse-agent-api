# ══════════════════════════════════════════════
# LLM Provider — escolha um dos três abaixo
# ══════════════════════════════════════════════
LLM_PROVIDER=openrouter   # openrouter | openai | anthropic

# OpenRouter (padrão)
OPENROUTER_API_KEY=sk-or-coloque-sua-chave-aqui
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct   # opcional

# OpenAI (ativar quando LLM_PROVIDER=openai)
# OPENAI_API_KEY=sk-coloque-sua-chave-aqui
# OPENAI_MODEL=gpt-4o   # opcional

# Anthropic (ativar quando LLM_PROVIDER=anthropic)
# ANTHROPIC_API_KEY=sk-ant-coloque-sua-chave-aqui
# ANTHROPIC_MODEL=claude-sonnet-4-5   # opcional

# ══════════════════════════════════════════════
# Segurança
# ══════════════════════════════════════════════
API_SECRET_KEY=gere-uma-string-aleatoria-e-segura-aqui

# ══════════════════════════════════════════════
# PostgreSQL + pgvector (RAG — opcional)
# Se não configurado, o RAG é desabilitado silenciosamente
# ══════════════════════════════════════════════
PG_HOST=localhost
PG_PORT=5432
PG_DB=hse_normas
PG_USER=postgres
PG_PASSWORD=sua-senha-aqui
